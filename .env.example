# Copy to .env and fill in. .env is gitignored.

# DeepSeek (OpenAI-compatible). For Claude via OpenRouter, also set API_BASE_URL/API_MODEL.
API_KEY=sk-your-deepseek-key
# API_BASE_URL=https://api.deepseek.com
# API_MODEL=deepseek-chat

# Email delivery via Resend (optional — leave RESEND_API_KEY empty to skip email).
RESEND_API_KEY=re_your_resend_key
# Must be the Resend account owner's address unless you've verified a domain.
EMAIL_TO=hieudinhvuong@gmail.com
# EMAIL_FROM=onboarding@resend.dev
